# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Group Configuration
# The main group where users need intro verification to participate
MAIN_GROUP_ID=-100xxxxxxxxxx

# Optional: Intro topic ID (if using Topics/Forums in the group)
# Run `node scripts/get-topic-id.js` to find your topic ID
INTRO_TOPIC_ID=

# Optional: Separate intro channel (leave blank to use the same group)
# If not set, users will post intros in the main group itself (recommended for simplicity)
INTRO_CHANNEL_ID=

# Bot Behavior
# Whether to delete messages from users who haven't introduced themselves (true/false)
DELETE_UNAUTHORIZED_MESSAGES=true

# How often to remind users to introduce themselves (in hours, 0 to disable)
REMINDER_INTERVAL_HOURS=24

# Intro Validation (optional)
# Minimum character count for a valid intro
MIN_INTRO_LENGTH=50

# Whether to use heuristic validation for intro format
ENABLE_FORMAT_VALIDATION=false

# Configurable intro format (JSON array of fields shown to new members)
# Default: ["Who are you & what do you do?","Where are you based?","One fun fact about you","How are you looking to contribute to Superteam MY?"]
INTRO_FORMAT=

# Admin Configuration
# Comma-separated list of Telegram user IDs who can use admin commands
ADMIN_USER_IDS=

# Database
# Path to SQLite database file
DATABASE_PATH=./data/bot.db

# Logging
LOG_LEVEL=info
